void setup(void) {
  pinMode(BTN_OK, INPUT);
  
  led.init();

  
  MX_DMA_Init(); // initalize DMA first
  MX_I2S1_Init();
  MX_RTC_Init();
  
  codec.init();
  if (HAL_I2S_Receive_DMA(&hi2s1, codec.audioBuffer, codec.bufferSize) == HAL_OK) led.setColor(0xffffff);
  card.init();

  while (!digitalRead(BTN_OK));
    card.createNewFile();
    led.setColor(0x0000ff);
    delay(100);
    led.setColor(0x000000);
    delay(100);
    led.setColor(0x0000ff);
    delay(100);
    led.setColor(0x000000);
    delay(100);
}

void loop(void) {
    if (codec.firstHalfFull) {
      if(card.updateFile((uint8_t *)codec.audioBuffer, codec.bufferSize)) led.setColor(0x0000ff);
      else led.setColor(0xff0000);
    }
    if (codec.secondHalfFull) {
      if(card.updateFile((uint8_t *)codec.audioBuffer[codec.bufferSize], codec.bufferSize)) led.setColor(0x00ff00);
      else led.setColor(0xff0000);
    }
    if (digitalRead(BTN_OK)) {
      led.setColor(0xffffff);
      delay(200);
      card.closeFile();
    }
}